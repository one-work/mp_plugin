page {
  height: 100%;
}

.button {
  text-align: center;
  background: #eeeeee;
  padding: 0.25rem 0.5rem;
  border-radius: 5px;
}

.p-3 {
  padding: 0.75rem;
}

.pt-1 {
  padding-top: 0.25rem;
}

.mt-1 {
  margin-top: 0.25rem;
}

.mt-4 {
  margin-top: 1rem;
}

.mx-3 {
  margin-left: 0.75rem;
  margin-right: 0.75rem;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

.text-centered {
  text-align: center;
}

.text-sm {
  font-size: 0.8rem;
}

.center {
  display: flex;
  height: 100%;
  justify-content: center;
  align-items: center;
  color: darkgrey;
}
